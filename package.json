{
  "name": "reuniones",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:reuniones": "vite build && powershell -Command \"Remove-Item -Recurse -Force ./reuniones/* -ErrorAction SilentlyContinue; Copy-Item -Recurse ./dist/* ./reuniones/\"",
    "deploy": "npm run build:reuniones && git add . && git commit -m \"Deploy Material Design and Icons update\" && git push origin master"
  },
  "dependencies": {
    "jsonata": "^2.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "vite": "^7.3.1"
  }
}